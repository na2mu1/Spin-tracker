<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="170dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#E6121212" android:padding="8dp">
    <TextView android:text="🎰 SpinTracker" android:textSize="12sp"
        android:textColor="#1D9E75" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <TextView android:id="@+id/tvLastEvent" android:text="শেষ: —"
        android:textSize="12sp" android:textColor="#FFFFFF"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tvSpinCount" android:text="স্পিন: ০"
        android:textSize="14sp" android:textColor="#5DCAA5" android:textStyle="bold"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvAvg" android:text="গড়: —"
        android:textSize="11sp" android:textColor="#AAAAAA"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>
    <Button android:id="@+id/btnSpin" android:text="+ স্পিন"
        android:textSize="11sp" android:textColor="#FFFFFF"
        android:layout_width="match_parent" android:layout_height="32dp"
        android:backgroundTint="#333333" android:layout_marginBottom="4dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnBigwin" android:text="BIG"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:layout_width="0dp" android:layout_height="30dp"
            android:layout_weight="1" android:backgroundTint="#0F6E56"
            android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btnSuper" android:text="SUP"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:layout_width="0dp" android:layout_height="30dp"
            android:layout_weight="1" android:backgroundTint="#533AB7"
            android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btnBonus" android:text="BON"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:layout_width="0dp" android:layout_height="30dp"
            android:layout_weight="1" android:backgroundTint="#BA7517"/>
    </LinearLayout>
    <Button android:id="@+id/btnReset" android:text="🔄 রিসেট"
        android:textSize="10sp" android:textColor="#FFFFFF"
        android:layout_width="match_parent" android:layout_height="28dp"
        android:backgroundTint="#444444" android:layout_marginTop="4dp"/>
</LinearLayout>
