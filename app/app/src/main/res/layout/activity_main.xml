<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp"
    android:gravity="center" android:background="#121212">
    <TextView android:text="🎰 Spin Tracker" android:textSize="24sp"
        android:textColor="#FFFFFF" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"/>
    <TextView android:id="@+id/tvStatus" android:text="চালু করতে বাটন চাপুন"
        android:textSize="14sp" android:textColor="#FFD700"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btnStart" android:text="▶ ট্র্যাকার চালু করুন"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#1D9E75" android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btnStop" android:text="⏹ বন্ধ করুন"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#993C1D" android:textColor="#FFFFFF"/>
</LinearLayout>
